{
    "$schema": "/etc/xdg/swaync/configSchema.json",
    "positionX": "right",
    "positionY": "top",
    "cssPriority": "user",

    "control-center-width": 450,
    "control-center-height": 900,
    "control-center-margin-top": 2,
    "control-center-margin-bottom": 2,
    "control-center-margin-right": 1,
    "control-center-margin-left": 0,

    "notification-window-width": 400,
    "notification-body-image-height": 500,
    "notification-body-image-width": 500,
    "notification-inline-replies": true,
    "notification-2fa-action": true,

    "timeout": 3,
    "timeout-low": 2,
    "timeout-critical": 6,

    "fit-to-screen": true,
    "keyboard-shortcuts": true,
    "image-visibility": "when-available",
    "transition-time": 200,
    "hide-on-clear": false,
    "hide-on-action": false,
    "script-fail-notify": true,

    "widgets": [
        "mpris",
        "volume",
        "backlight",
        "dnd",
        "title",
        "notifications",
        "buttons-grid"
    ],
    "widget-config": {
        "volume": {
            "label": "箚빢",
            "show-per-app": true
        },
        "backlight": {
            "device": "amdgpu_bl1",
            "label": "箚깲",
            "min": 0
        },
        "dnd": {
            "text": "Do not disturb"
        },
        "title": {
            "text": "Notifications",
            "clear-all-button": true,
            "button-text": " clear all 箚㈉ "
        },
        "buttons-grid": {
            "buttons-per-row": 3,
            "actions": [
                {
                    "label": "箚씇",
                    "type": "toggle",
                    "command": "wpctl set-mute @DEFAULT_SINK@ toggle"
                },
                {
                    "label": "箚뜭",
                    "type": "toggle",
                    "command": "wpctl set-mute @DEFAULT_SOURCE@ toggle"
                },
                {
                    "label": "箚뼦",
                    "command": "nm-connection-editor"
                },
                {
                    "label": "箚궚",
                    "command": "blueman-manager"
                },
                {
                    "label": "茶쨫",
                    "type": "toggle",
                    "command": "bash -c '$HOME/.config/swaync/utils/toggle-power-profile.sh' > /dev/null 2>&1"
                },
                {
                    "label": "茶찈",
                    "type": "toggle",
                    "command": "bash -c '$HOME/.config/swaync/utils/toggle-blue-light.sh' > /dev/null 2>&1"
                }
            ]
        }
    }
}
